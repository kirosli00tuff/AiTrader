# =============================================================================
# Market AI Lab — example environment file. Copy to `.env` and fill in.
#
# SECURITY: API keys are NEVER stored in YAML config. The config files only
# reference the *names* of these environment variables (see
# config/default_config.yaml -> data_sources.*). The demo runs fully OFFLINE
# with all of these UNSET (every external adapter has a deterministic mock
# fallback). Set them only when you intend to use real data sources.
#
# Live TRADING remains DISABLED regardless of these keys; enabling live is a
# separate in-app approval-gate action.
# =============================================================================

# --- Whale / smart-money live-fetch flags (DEFAULT OFF — offline mocks) ---
# The whole app runs offline on deterministic mocks unless you opt in here.
# Leave unset/false for paper-training; set to 1 only to hit the live free APIs.
WHALE_LIVE_ENABLED=false     # RESERVED crypto feeds (ClankApp / Whale Alert), off
SEC_EDGAR_ENABLED=false      # SEC EDGAR 13F institutional feed
# Contact for the SEC fair-access User-Agent header (REQUIRED before SEC live
# fetches; env only — NEVER commit a real address to YAML/config).
SEC_EDGAR_CONTACT_EMAIL=

# --- Whale / smart-money advisory sources ---
# SEC EDGAR 13F is the SOLE ACTIVE whale source, official free data.sec.gov REST.
# NO key needed (just a descriptive User-Agent). SEC_API_KEY is an OPTIONAL
# override only. DELAYED disclosure, context not live flow.
SEC_API_KEY=

# ClankApp (RESERVED optional crypto/on-chain feed, not in the active chain).
# Fully free, ~10 calls/min, ~21 chains. Key optional; without it, mock fallback.
CLANKAPP_API_KEY=

# Whale Alert API (RESERVED optional crypto feed, limited free tier), large
# on-chain crypto transfers. Not in the active chain.
WHALE_ALERT_API_KEY=

# RESERVED, not implemented: Unusual Whales Pro, the real-time PAID upgrade for
# richer equities smart-money data (options flow, dark pool, congressional,
# insider, and 13F), at roughly 48 dollars per month. Reserved name only, no
# adapter wired, pending an operator decision.
UNUSUAL_WHALES_API_KEY=

# --- Alpaca (paper + market data; stocks + crypto) ---
# A PAPER / DATA key is enough — NO live brokerage account is required, so this
# works from regions where Alpaca live trading is unavailable (e.g. Canada).
# Live TRADING stays DISABLED regardless; these only enable real-time data and
# paper-order submission (market_data.source: alpaca, venues.alpaca paper API).
#
# Resolution precedence per field: in-app saved credential first, then these
# env vars (paper-specific name first, then the generic name).
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_API_SECRET=
# Generic fallbacks (used if the *_PAPER_* names above are unset):
ALPACA_API_KEY=
ALPACA_API_SECRET=
# Optional: dedicated market-data key/secret (falls back to the paper key above).
ALPACA_DATA_API_KEY=
ALPACA_DATA_API_SECRET=
# Paper trading + data API base URLs (override only if Alpaca changes them).
ALPACA_PAPER_BASE=https://paper-api.alpaca.markets
ALPACA_DATA_BASE=https://data.alpaca.markets

# --- Optional: real LLM council (Layer-2 advisory) ---
# The council runs fully offline with these UNSET: any provider whose key is
# missing returns a clearly-labelled deterministic MOCK verdict. Set a key to
# use that provider for real. The REAL council is only wired into the engine
# when config `llm.use_real_council: true` AND the engine runs with --bridge.
#   llm_primary   = OpenAI    (gpt-5.5)          -> OPENAI_API_KEY
#   llm_secondary = Anthropic (claude-opus-4-8)  -> ANTHROPIC_API_KEY
#   llm_tertiary  = Google    (gemini-3.1-pro)   -> GEMINI_API_KEY
#   base-check gate (claude-haiku-4-5)           -> ANTHROPIC_API_KEY (shared w/ secondary)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- TODO: future venues (adapters scaffolded, not yet implemented) ---
# Coinbase replaces Binance for crypto (Binance does not operate in Canada).
# Reserved only — Coinbase live execution is not implemented; paper/sim only.
# COINBASE_API_KEY=
# COINBASE_API_SECRET=
# IBKR_ACCOUNT=
