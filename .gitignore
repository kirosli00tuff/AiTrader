# --- Secrets (NEVER commit) ---
.env
*.pem
*.key
.keystore/

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
*.egg-info/

# --- C++ / CMake build artifacts ---
build/
*.o
*.a
*.so
CMakeCache.txt
CMakeFiles/

# --- PyInstaller desktop-app build output (keep ui/MarketAILab.spec tracked) ---
dist/
/build-pyinstaller/
*.pyc

# --- SQLite runtime DB (regenerated by ops/demo.py) ---
*.db
*.db-wal
*.db-shm

# --- UI runtime state ---
ui/weight_overrides.json

# --- Local 24/7 launcher runtime state (ops/start.sh) ---
.run/

# --- Nightly DB backups (dated snapshots; not a deliverable) ---
backups/

# --- Automatic evidence records for unexplained failures (ops/evidence.py) ---
diagnostics/

# --- Scratch demo DB a no---db mal_engine invocation writes (never production) ---
mal_demo.db

# --- Rotated file logs (week-long run) ---
logs/

# --- Scratch API captures (whale-fixture recording; not a deliverable) ---
scratch_captures/

# --- Editor / OS ---
.vscode/
.idea/
.DS_Store

# React GUI (web/) + API control state
node_modules/
web/dist/
web/node_modules/
.control/
